<mvc:View
    controllerName="p2p.app.controller.Materials"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc">
    <Page title="{i18n>materialsTitle}" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <Table id="materialTable" items="{path: '/Materials', parameters: {$count: true}}" growing="true">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{= 'Materials: ' + (${/Materials/$count} || 0)}"/>
                        <ToolbarSpacer/>
                        <SearchField width="20rem" liveChange=".onSearch" placeholder="{i18n>searchMaterialPlaceholder}"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="{i18n>colMaterialName}"/></Column>
                    <Column><Text text="{i18n>colDescription}"/></Column>
                    <Column><Text text="{i18n>colUnit}"/></Column>
                    <Column hAlign="End"><Text text="{i18n>colUnitPrice}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <ObjectIdentifier title="{materialName}"/>
                            <Text text="{description}"/>
                            <Text text="{unit}"/>
                            <ObjectNumber number="{unitPrice}" unit="USD"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
