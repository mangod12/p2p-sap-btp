<mvc:View
    controllerName="p2p.app.controller.PRList"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core">
    <Page title="{i18n>prListTitle}" showNavButton="true" navButtonPress=".onNavBack">
        <headerContent>
            <Button icon="sap-icon://add" text="{i18n>btnCreate}" type="Emphasized" press=".onCreate"/>
        </headerContent>
        <content>
            <IconTabBar id="statusTabBar" select=".onFilterSelect" class="sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter text="{i18n>filterAll}" key="All" icon="sap-icon://list"/>
                    <IconTabFilter text="{i18n>filterDraft}" key="Draft" count="{prCounts>/Draft}" icon="sap-icon://edit" iconColor="Default"/>
                    <IconTabFilter text="{i18n>filterSubmitted}" key="Submitted" count="{prCounts>/Submitted}" icon="sap-icon://paper-plane" iconColor="Critical"/>
                    <IconTabFilter text="{i18n>filterApproved}" key="Approved" count="{prCounts>/Approved}" icon="sap-icon://accept" iconColor="Positive"/>
                    <IconTabFilter text="{i18n>filterRejected}" key="Rejected" count="{prCounts>/Rejected}" icon="sap-icon://decline" iconColor="Negative"/>
                    <IconTabFilter text="{i18n>filterConverted}" key="Converted" count="{prCounts>/Converted}" icon="sap-icon://complete" iconColor="Positive"/>
                </items>
                <content>
                    <Table id="tbl"
                           items="{path: '/PurchaseRequisitions', parameters: {$count: true}}"
                           growing="true" growingThreshold="25" mode="SingleSelectMaster"
                           itemPress=".onOpen">
                        <headerToolbar>
                            <OverflowToolbar>
                                <Title text="{= ${/PurchaseRequisitions/$count} !== undefined ? 'Total: ' + ${/PurchaseRequisitions/$count} : ''}"/>
                                <ToolbarSpacer/>
                                <SearchField width="20rem" liveChange=".onSearch" placeholder="{i18n>searchPRPlaceholder}"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <columns>
                            <Column><Text text="{i18n>colPRNumber}"/></Column>
                            <Column><Text text="{i18n>colMaterial}"/></Column>
                            <Column hAlign="End"><Text text="{i18n>colQty}"/></Column>
                            <Column><Text text="{i18n>colVendor}"/></Column>
                            <Column><Text text="{i18n>colRequestedBy}"/></Column>
                            <Column><Text text="{i18n>colNeededBy}"/></Column>
                            <Column><Text text="{i18n>colStatus}"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem type="Navigation" press=".onOpen">
                                <cells>
                                    <ObjectIdentifier title="{prNumber}"/>
                                    <Text text="{materialName}"/>
                                    <ObjectNumber number="{quantity}"/>
                                    <Text text="{vendorName}"/>
                                    <Text text="{requestedBy}"/>
                                    <Text text="{path: 'neededBy', type: 'sap.ui.model.odata.type.Date'}"/>
                                    <ObjectStatus text="{status}" state="{
                                        path: 'status',
                                        formatter: '.formatter.statusState'
                                    }"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </content>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>
